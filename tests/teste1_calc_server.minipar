# Teste 1 — Calculadora Aritmetica: Servidor (Computador 2)
# Traduzido do Programa de Teste 1 do professor.
# O servidor recebe uma operacao e dois operandos via canal e retorna o resultado.
# Execucao:
#   1. Iniciar este servidor: ./mcc tests/teste1_calc_server.minipar
#   2. Iniciar o cliente em outro terminal: ./mcc tests/teste1_calc_client.minipar

func calcular(op: string, v1: f64, v2: f64) -> f64 {
    switch (op) {
        "+" => { return v1 + v2 }
        "-" => { return v1 - v2 }
        "*" => { return v1 * v2 }
        "/" => { return v1 / v2 }
    }
    return 0
}

# Declaracao do canal de comunicacao da calculadora associada ao computador servidor.
# Computador 2 (servidor) escuta na porta 5001.
let descricao: string = "Calculadora Servidor — Operacoes: +, -, *, /"
s_channel calculadora(calcular, descricao, "localhost", 5001)

func main() {
    print("Servidor Calculadora iniciado.")
    print("Aguardando conexao do cliente na porta 5001...")
}
