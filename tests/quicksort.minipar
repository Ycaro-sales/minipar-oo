# ALVO: depende de features ainda nao implementadas:
#   (1) atribuicao por indice  arr[i] = x  (gramatica so permite <id> = <expr>)
#   (2) arrays passados por referencia (para swap mutar o original)
#   (3) tipo [i32] em parametros (parser le apenas o literal do token atual)
# Contorno atual: parametros de array declarados como `any`
# Hoje ainda falha no semantico (arr[i]=x); serve como especificacao do destino.

func swap(arr: any, i: i32, j: i32) {
    let tmp: i32 = arr[i]
    arr[i] = arr[j]
    arr[j] = tmp
}

func partition(arr: any, low: i32, high: i32) -> i32 {
    let pivot: i32 = arr[high]
    let i: i32 = low - 1
    let j: i32 = low
    while (j < high) {
        if (arr[j] <= pivot) {
            i = i + 1
            swap(arr, i, j)
        }
        j = j + 1
    }
    swap(arr, i + 1, high)
    return i + 1
}

func quicksort(arr: any, low: i32, high: i32) {
    if (low < high) {
        let p: i32 = partition(arr, low, high)
        quicksort(arr, low, p - 1)
        quicksort(arr, p + 1, high)
    }
}

func main() {
    let arr: [i32] = [5, 2, 9, 1, 7, 3]
    quicksort(arr, 0, 5)
    let i: i32 = 0
    while (i < 6) {
        print(arr[i])
        i = i + 1
    }
}
