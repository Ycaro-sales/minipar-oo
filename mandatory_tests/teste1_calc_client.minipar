# Teste 1 — Calculadora Aritmetica: Cliente (Computador 1)
# Traduzido do Programa de Teste 1 do professor.
# O cliente envia ao servidor (computador 2), via canal tipado, um fluxo de
# requisicoes (operacao, operando1, operando2). O servidor calcula e imprime.
# Execucao:
#   1. Iniciar o servidor primeiro: ./mcc mandatory_tests/teste1_calc_server.minipar
#   2. Iniciar este cliente:        ./mcc mandatory_tests/teste1_calc_client.minipar

# Canal tipado: cada mensagem carrega (operacao, operando1, operando2).
c_channel calculadora<(string, f64, f64)>("localhost", 5001)

func main() {
    seq {
        # Apresentar opcoes da calculadora ao usuario
        print("=== Calculadora Aritmetica ===")
        print("Operacoes disponiveis: +, -, *, /")
        print("")

        # Demonstracao com operacoes pre-definidas.
        print("Teste 1: 10 + 5")
        calculadora.send(("+", 10, 5))

        print("Teste 2: 20 - 8")
        calculadora.send(("-", 20, 8))

        print("Teste 3: 6 * 7")
        calculadora.send(("*", 6, 7))

        print("Teste 4: 100 / 4")
        calculadora.send(("/", 100, 4))

        print("")
        print("Todos os testes concluidos.")
    }

    # Encerra a conexao com o servidor
    calculadora.close()
    print("Conexao encerrada.")
}
